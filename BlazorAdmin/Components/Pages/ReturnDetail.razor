@page "/return-detail/{HoaDonId:guid}"
@using Data.Models
@using API.Models.DTO
@inject HttpClient HttpClient
@inject NavigationManager Navigation
@inject ITaiKhoanService TaiKhoanService

<h2 class="mb-4 text-primary">Chi tiết hóa đơn #@HoaDonId</h2>

@if (hoaDon == null || hoaDonChiTiets == null)
{
    <p>Đang tải...</p>
}
else
{
    <EditForm Model="@returnModel" OnValidSubmit="@HandleSubmit">
        <table class="table table-bordered table-hover align-middle mb-4">
            <thead class="table-primary">
                <tr>
                    <th>#</th>
                    <th>Tên sản phẩm</th>
                    <th>Số lượng đã mua</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    <th>Chọn trả</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < hoaDonChiTiets.Count; i++)
                {
                    var item = hoaDonChiTiets[i];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@item.Giays.TenGiay</td>
                        <td>@item.SoLuongSanPham</td>
                        <td>@item.Gia.ToString("N0")₫</td>
                        <td>@((item.Gia * item.SoLuongSanPham).ToString("N0"))₫</td>
                        <td>
                            <button class="btn btn-sm btn-danger" type="button" data-bs-toggle="collapse" data-bs-target="#return@(item.HoaDonChiTietId)">Chọn trả</button>
                        </td>
                    </tr>
                    <tr class="collapse" id="return@(item.HoaDonChiTietId)">
                        <td colspan="6">
                            <div class="row g-2 align-items-center">
                                <div class="col-auto">
                                    <label for="qtyReturn@(item.HoaDonChiTietId)" class="col-form-label">Số lượng trả:</label>
                                </div>
                                <div class="col-auto">
                                    <InputNumber id="qtyReturn@(item.HoaDonChiTietId)" class="form-control" @bind-Value="returnModel.ReturnItems[i].SoLuongTra" min="1" max="@item.SoLuongSanPham" style="width:80px;" />
                                    <InputHidden @bind-Value="returnModel.ReturnItems[i].GiayId" />
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="row mb-4">
            <div class="col-lg-8 mb-3 mb-lg-0">
                <div class="card shadow-sm p-3 h-100">
                    <h5 class="mb-3 text-success">Danh sách trả hàng</h5>
                    <table class="table table-bordered align-middle mb-0">
                        <thead class="table-success">
                            <tr>
                                <th>#</th>
                                <th>Tên sản phẩm</th>
                                <th>Số lượng trả</th>
                                <th>Đơn giá</th>
                                <th>Thành tiền</th>
                                <th>Xóa</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in returnModel.ReturnItems.Where(r => r.SoLuongTra > 0))
                            {
                                var chiTiet = hoaDonChiTiets.FirstOrDefault(c => c.GiayId == item.GiayId);
                                <tr>
                                    <td>@(returnModel.ReturnItems.IndexOf(item) + 1)</td>
                                    <td>@chiTiet?.Giays.TenGiay</td>
                                    <td>@item.SoLuongTra</td>
                                    <td>@chiTiet?.Gia.ToString("N0")₫</td>
                                    <td>@((chiTiet?.Gia * item.SoLuongTra).ToString("N0"))₫</td>
                                    <td><button class="btn btn-sm btn-outline-danger" type="button" @onclick="() => RemoveItem(item.GiayId)">Xóa</button></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card shadow-sm p-3 h-100">
                    <h5 class="mb-3 text-primary">Tính tiền hoàn trả</h5>
                    <div class="mb-3">
                        <div><strong>Khách hàng:</strong> @hoaDon.TenCuaKhachHang</div>
                        <div><strong>SĐT:</strong> @hoaDon.SDTCuaKhachHang</div>
                        <div><strong>Ngày mua:</strong> @hoaDon.NgayTao.ToString("dd/MM/yyyy")</div>
                        <div><strong>Tổng tiền hóa đơn:</strong> @hoaDon.TongTienSauKhiGiam.ToString("N0")₫</div>
                    </div>
                    <table class="table table-bordered mb-0">
                        <tbody>
                            <tr>
                                <th>Tổng tiền trả hàng</th>
                                <td>@tongTienTra.ToString("N0")₫</td>
                            </tr>
                            <tr>
                                <th>Voucher giảm giá</th>
                                <td>@(voucher != null ? $"-{voucher.PhanTram}%" : "0%")</td>
                            </tr>
                            <tr class="table-info">
                                <th>Số tiền hoàn trả</th>
                                <td><strong>@tongTienSauGiam.ToString("N0")₫</strong></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <button type="submit" class="btn btn-success mt-4">Hoàn tất trả hàng</button>
        <a href="/return-search" class="btn btn-secondary mt-4">Quay lại</a>
    </EditForm>
}

@code {
    [Parameter]
    public Guid HoaDonId { get; set; }

    private HoaDon hoaDon;
    private List<HoaDonChiTiet> hoaDonChiTiets;
    private Voucher voucher;
    private float tongTienTra;
    private float tongTienSauGiam;
    private ReturnModel returnModel = new ReturnModel();

    private class ReturnModel
    {
        public List<ReturnItemRequest> ReturnItems { get; set; } = new List<ReturnItemRequest>();
        public Guid? VoucherId { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        hoaDon = await HttpClient.GetFromJsonAsync<HoaDon>($"/api/Return/hoa-don/{HoaDonId}");
        hoaDonChiTiets = await HttpClient.GetFromJsonAsync<List<HoaDonChiTiet>>($"/api/Return/hoa-don/{HoaDonId}/chi-tiet");
        returnModel.ReturnItems = hoaDonChiTiets.Select(c => new ReturnItemRequest { GiayId = c.GiayId, SoLuongTra = 0 }).ToList();

        // Giả lập voucher (có thể lấy từ API)
        if (hoaDon.VoucherId.HasValue)
        {
            voucher = await HttpClient.GetFromJsonAsync<Voucher>($"/api/Vouchers/{hoaDon.VoucherId}");
        }

        CalculateTotals();
    }

    private void CalculateTotals()
    {
        tongTienTra = returnModel.ReturnItems.Sum(item =>
            hoaDonChiTiets.FirstOrDefault(c => c.GiayId == item.GiayId)?.Gia * item.SoLuongTra ?? 0);
        tongTienSauGiam = tongTienTra * (1 - (voucher?.PhanTram ?? 0) / 100);
    }

    private void RemoveItem(Guid giayId)
    {
        var item = returnModel.ReturnItems.FirstOrDefault(r => r.GiayId == giayId);
        if (item != null) item.SoLuongTra = 0;
        CalculateTotals();
        StateHasChanged();
    }

    private async Task HandleSubmit()
    {
        var request = new CreateReturnRequest
        {
            HoaDonId = HoaDonId,
            ReturnItems = returnModel.ReturnItems.Where(r => r.SoLuongTra > 0).ToList(),
            VoucherId = returnModel.VoucherId,
            TaiKhoanId = (await TaiKhoanService.GetByUsernameAsync("current_user")).TaikhoanId // Thay bằng tài khoản hiện tại
        };

        var response = await HttpClient.PostAsJsonAsync("/api/Return/create-return", request);
        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/return-search");
        }
        else
        {
            Console.WriteLine("Lỗi khi tạo trả hàng.");
        }
    }
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>